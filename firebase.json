{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/node_modules/**",
      "README.md",
      "SKILL.md",
      "SKILL-GESTAO-COMERCIAL.md",
      ".github/**"
    ],
    "rewrites": [
      {
        "source": "/crm",
        "destination": "/crm.html"
      },
      {
        "source": "/crm/**",
        "destination": "/crm.html"
      },
      {
        "source": "/relatorios",
        "destination": "/relatorios.html"
      },
      {
        "source": "/relatorios/**",
        "destination": "/relatorios.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
