{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**.*",
      "**/node_modules/**",
      "README.md"
    ],
    "rewrites": [
      {
        "source": "/crm",
        "destination": "/crm.html"
      },
      {
        "source": "/crm/**",
        "destination": "/crm.html"
      },
      {
        "source": "/relatorios",
        "destination": "/relatorios.html"
      },
      {
        "source": "/relatorios/**",
        "destination": "/relatorios.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|html)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ]
  }
}
